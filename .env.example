# ── AnfieldVoice — Environment Variables ─────────────────────────────────
# Copy this to .env and fill in your production values
# ──────────────────────────────────────────────────────────────────────────

# Database
ANFIELDVOICE_DB_HOST=db
ANFIELDVOICE_DB_PORT=5432
ANFIELDVOICE_DB_USER=anfieldvoice
ANFIELDVOICE_DB_PASSWORD=changeme-this-password
ANFIELDVOICE_DB_NAME=anfieldvoice

# Server
ANFIELDVOICE_PORT=8000
ANFIELDVOICE_WORKERS=2

# Auth — CHANGE THIS in production
ANFIELDVOICE_JWT_SECRET=generate-a-random-secret-at-least-32-chars
ANFIELDVOICE_JWT_EXPIRY_HOURS=24
