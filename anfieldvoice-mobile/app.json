{
  "expo": {
    "name": "AnfieldVoice",
    "slug": "anfieldvoice-mobile",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "anfieldvoice",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.redcapetech.anfieldvoice",
      "infoPlist": {
        "NSFaceIDUsageDescription": "AnfieldVoice uses Face ID or Touch ID to securely access your account without re-entering your password.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": []
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.redcapetech.anfieldvoice",
      "permissions": [],
      "intentFilters": []
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
